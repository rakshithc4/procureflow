# Copy to .env.local and fill in real values. Never commit .env* (see .gitignore).

# From ADT Service Binding "ZUI_PROCUREMENT_O4" publish screen (T2.2).
SAP_BASE_URL=https://<your-subaccount>.abap-web.<region>.hana.ondemand.com
SAP_SERVICE_PATH=/sap/opu/odata4/sap/zui_procurement_o4/srvd/sap/zprocurement_srv/0001/
SAP_USER=PROCURE_API
SAP_PASS=

NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Set to 1 for local/e2e mock mode: SAP calls are served by an in-memory
# fixture store (src/mocks/) via MSW instead of the real BTP system — the
# SAP_* values above can stay as placeholders when this is set.
MOCK_SAP=0
